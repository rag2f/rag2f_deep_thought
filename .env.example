# ============================================================================
# RAG2F Configuration - Environment Variables
# ============================================================================
# This file contains the environment variables to configure RAG2F and the 
# rag2f-openai-embedder plugin for use with hello_rag2f.py
#
# To use this file:
# 1. Rename this file to .env (without .example)
# 2. Insert your actual values
# 3. The file will be automatically loaded by RAG2F via Spock
# ============================================================================
# RAG2F Core Configuration
# ============================================================================
# Default embedder plugin ID to use
# Must match one of the configured plugins
RAG2F__RAG2F__EMBEDDER_DEFAULT="rag2f_openai_embedder"
# ============================================================================
# OpenAI Embedder Plugin Configuration (rag2f-openai-embedder)
# ============================================================================
RAG2F__PLUGINS__RAG2F_OPENAI_EMBEDDER__BASE_URL="http://127.0.0.1:8010"
# Embedding model to use
RAG2F__PLUGINS__RAG2F_OPENAI_EMBEDDER__MODEL="mlx-community/embeddinggemma-300m-8bit"
# Embedding vector size (must match the model)
RAG2F__PLUGINS__RAG2F_OPENAI_EMBEDDER__SIZE="768"
# API request timeout (in seconds)
RAG2F__PLUGINS__RAG2F_OPENAI_EMBEDDER__TIMEOUT="30.0"
# Maximum number of retries in case of error
RAG2F__PLUGINS__RAG2F_OPENAI_EMBEDDER__MAX_RETRIES="2"
RAG2F__PLUGINS__RAG2F_OPENAI_EMBEDDER__API_KEY="test"
RAG2F__PLUGINS__RAG2F_DEEP_THOUGHT__DEDUP_KEY=8c323a051fc680456c2409727cee0f4edd0609062600a51fbdca7edc766c0000
RAG2F__PLUGINS__RAG2F_DEEP_THOUGHT__DB_PATH=":memory:"
RAG2F__PLUGINS__RAG2F_DEEP_THOUGHT__FLUX_STORE_DB_PATH=":memory:"
RAG2F__PLUGINS__RAG2F_DEEP_THOUGHT__FLUX_QUEUE_BACKEND="redis"
RAG2F__PLUGINS__RAG2F_DEEP_THOUGHT__REDIS_URL="redis://:rag2f-devcontainer-redis@redis:6379/0"
RAG2F__PLUGINS__RAG2F_DEEP_THOUGHT__FLUX_STREAM_NAME="rag2f_deep_thought:flux:tasks"
RAG2F__PLUGINS__RAG2F_DEEP_THOUGHT__FLUX_CONSUMER_GROUP="rag2f_deep_thought:flux:workers"